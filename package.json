{
  "name": "@mxmweb/docs-generator",
  "version": "1.2.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "docs-gen": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "nodemon --exec \"tsx\" src/index.ts",
    "start": "node dist/run-test.js",
    "test:run": "tsx src/run-test.ts",
    "preview": "tsx src/run-test.ts preview",
    "docs-gen": "node dist/cli.js",
    "postbuild": "echo '✅ 构建完成'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "文档生成器 - 基于 Vite + React 的文档站点生成工具",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "glob": "^10.3.10",
    "lowdb": "^7.0.1",
    "minimist": "^1.2.8",
    "pandoc-wasm": "^0.0.2",
    "pandocjs": "2.9.2-1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^9.0.1",
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "^8.1.0",
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "zod": "^3.23.0"
  }
}
